{
  "name": "@vzen/ui",
  "version": "0.1.0",
  "private": false,
  "description": "vZen shared UI component library",
  "type": "module",
  "main": "./dist/vzen-ui.umd.cjs",
  "module": "./dist/vzen-ui.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/vzen-ui.js",
      "require": "./dist/vzen-ui.umd.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build && vue-tsc --emitDeclarationOnly",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint src --ext .ts,.vue"
  },
  "peerDependencies": {
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "@vue/tsconfig": "^0.5.0",
    "unocss": "^0.59.0",
    "vite": "^5.2.0",
    "vue": "^3.4.0",
    "vue-tsc": "^2.0.0"
  }
}
