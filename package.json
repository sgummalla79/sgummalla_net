{
  "name": "vzen",
  "private": true,
  "scripts": {
    "dev": "concurrently \"pnpm --filter @vzen/client dev\" \"pnpm --filter @vzen/server dev\"",
    "build": "pnpm --filter @vzen/ui build && pnpm --filter @vzen/client build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "format": "prettier --write \"**/*.{ts,vue,css,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,vue,css,json,md}\"",
    "check": "pnpm --filter @vzen/ui exec vue-tsc --noEmit && pnpm format:check && pnpm --filter @vzen/ui exec vite build"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "concurrently": "^8.2.2",
    "eslint": "^8.57.0",
    "eslint-plugin-vue": "^9.24.0",
    "prettier": "^3.2.5",
    "typescript": "^5.4.0"
  }
}
