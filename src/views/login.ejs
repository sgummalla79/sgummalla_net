<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Sign In — vZen Solutions</title>
  <script src="/js/theme.js"></script>
  <link rel="stylesheet" href="/css/base.css">
  <link rel="stylesheet" href="/css/login.css">
</head>
<body>
<div class="login-page">

  <!-- Pi background symbol -->
  <div class="pi-bg">π</div>
  <!-- Infinity symbol -->
  <div class="inf-bg">∞</div>

  <!-- Top bar -->
  <div class="login-bar">
    <div class="login-logo">vZen Solutions</div>
    <button class="theme-toggle" onclick="toggleTheme()" aria-label="Toggle theme">
      <svg class="icon-sun" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <circle cx="12" cy="12" r="5"/>
        <line x1="12" y1="2" x2="12" y2="4"/><line x1="12" y1="20" x2="12" y2="22"/>
        <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
        <line x1="2" y1="12" x2="4" y2="12"/><line x1="20" y1="12" x2="22" y2="12"/>
        <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
      </svg>
      <svg class="icon-moon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/>
      </svg>
    </button>
  </div>

  <!-- Form -->
  <div class="login-center">
    <div class="login-card">

      <h1 class="login-headline">Sign In.</h1>
      <p class="login-sub">Identity Gateway · vZen Solutions</p>

      <% if (error) { %>
      <div class="login-error">
        <svg width="13" height="13" viewBox="0 0 16 16" fill="none" style="flex-shrink:0;margin-top:1px">
          <circle cx="8" cy="8" r="7" stroke="currentColor" stroke-width="1.5"/>
          <path d="M8 5v3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          <circle cx="8" cy="11" r=".75" fill="currentColor"/>
        </svg>
        <%= error %>
      </div>
      <% } %>

      <form action="/auth/credentials" method="POST">
        <div class="field">
          <input class="field-input" name="email" type="email"
                 placeholder="Email address" autocomplete="email" required>
        </div>
        <div class="field">
          <input class="field-input" name="password" type="password"
                 placeholder="Password" autocomplete="current-password" required>
        </div>
        <button class="btn-signin" type="submit">Sign In</button>
      </form>

      <div class="login-or">
        <div class="login-or-line"></div>
        <span class="login-or-text">or</span>
        <div class="login-or-line"></div>
      </div>

      <a href="/auth/auth0" class="btn-auth0">
        <div class="auth0-dot"></div>
        Continue with Auth0
      </a>

    </div>
  </div>

  <!-- Footer -->
  <div class="login-footer">
    <span>SAML 2.0 · OAuth 2.0 · OIDC</span>
    <span>vZen Solutions</span>
  </div>

</div>
</body>
</html>
