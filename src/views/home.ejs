<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>vZen Solutions</title>
  <script src="/js/theme.js"></script>
  <link rel="stylesheet" href="/css/base.css">
  <link rel="stylesheet" href="/css/home.css">
</head>
<body>
<div class="shell">

  <!-- Pi background symbol -->
  <div class="pi-bg">π</div>
  <!-- Infinity symbol -->
  <div class="inf-bg">∞</div>

  <!-- Nav -->
  <nav>
    <a href="/" class="nav-brand">
      <div class="nav-live-dot"></div>
      vZen Solutions
    </a>

    <div class="nav-links">
      <a href="/" class="nav-link nav-link--active">Home</a>
      <a href="/auths" class="nav-link">Available Auths</a>
    </div>

    <div class="nav-right">
      <span class="nav-email"><%= fullName %></span>
      <button class="theme-toggle" onclick="toggleTheme()" aria-label="Toggle theme">
        <svg class="icon-sun" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <circle cx="12" cy="12" r="5"/>
          <line x1="12" y1="2" x2="12" y2="4"/><line x1="12" y1="20" x2="12" y2="22"/>
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
          <line x1="2" y1="12" x2="4" y2="12"/><line x1="20" y1="12" x2="22" y2="12"/>
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
        </svg>
        <svg class="icon-moon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/>
        </svg>
      </button>
      <a href="/logout" class="btn-signout">Sign out</a>
    </div>
  </nav>

  <!-- Main -->
  <main>
    <div class="container">

      <% if (typeof error !== 'undefined' && error) { %>
      <div class="launch-error">
        <svg width="13" height="13" viewBox="0 0 16 16" fill="none" style="flex-shrink:0;margin-top:1px">
          <circle cx="8" cy="8" r="7" stroke="currentColor" stroke-width="1.5"/>
          <path d="M8 5v3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          <circle cx="8" cy="11" r=".75" fill="currentColor"/>
        </svg>
        <%= error %>
      </div>
      <% } %>

      <p class="eyebrow">Welcome back</p>
      <h1 class="headline"><%= fullName %><span class="headline-dot">.</span></h1>
      <p class="subline">Your session is active. Access any connected Salesforce Experience Cloud site seamlessly — no additional login required.</p>

      <div class="status-strip">
        <div class="status-item">
          <div class="status-dot"></div>
          Session active
        </div>
      </div>




    </div>
  </main>

  <!-- Footer -->
  <footer>
    <span class="footer-left">vZen Solutions · Identity Gateway</span>
    <div class="footer-right">
      <div class="nav-live-dot"></div>
      Live
    </div>
  </footer>

</div>
</body>
</html>
