<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Sign In · MyPortal</title>
  <script src="/js/theme.js"></script>
  <link rel="stylesheet" href="/css/base.css">
  <link rel="stylesheet" href="/css/login.css">
</head>
<body>
<div class="layout">

  <!-- Left decorative panel -->
  <div class="panel-left">
    <div class="arc arc-1"></div>
    <div class="arc arc-2"></div>
    <div class="arc arc-3"></div>

    <div class="left-top">
      <div class="left-logo">MyPortal</div>
    </div>

    <div class="left-middle">
      <p class="left-tagline">Identity Gateway</p>
      <h1 class="left-headline">Secure access,<br><em>seamlessly.</em></h1>
      <div class="left-rule"></div>
      <p class="left-body">
        Sign in once. Access Salesforce Experience Cloud
        automatically — no second login required.
      </p>
    </div>

    <div class="left-bottom">
      <p class="left-footer">SAML 2.0 · Auth0 · Node.js</p>
    </div>
  </div>

  <!-- Right form panel -->
  <div class="panel-right">

    <button class="theme-toggle" onclick="toggleTheme()" aria-label="Toggle theme">
      <svg class="icon-sun" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <circle cx="12" cy="12" r="5"/>
        <line x1="12" y1="2" x2="12" y2="4"/>
        <line x1="12" y1="20" x2="12" y2="22"/>
        <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
        <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
        <line x1="2" y1="12" x2="4" y2="12"/>
        <line x1="20" y1="12" x2="22" y2="12"/>
        <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
        <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
      </svg>
      <svg class="icon-moon" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/>
      </svg>
    </button>

    <div class="form-wrap">
      <h2 class="form-title">Welcome back.</h2>
      <p class="form-sub">Sign in to your account to continue.</p>

      <% if (error) { %>
      <div class="error-banner">
        <svg class="error-icon" width="14" height="14" viewBox="0 0 16 16" fill="none">
          <circle cx="8" cy="8" r="7" stroke="currentColor" stroke-width="1.5"/>
          <path d="M8 5v3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          <circle cx="8" cy="11" r=".75" fill="currentColor"/>
        </svg>
        <%= error %>
      </div>
      <% } %>

      <form action="/auth/credentials" method="POST">
        <div class="field">
          <label class="field-label" for="email">Email address</label>
          <input
            class="field-input"
            id="email"
            name="email"
            type="email"
            placeholder="you@company.com"
            autocomplete="email"
            required>
        </div>
        <div class="field">
          <label class="field-label" for="password">Password</label>
          <input
            class="field-input"
            id="password"
            name="password"
            type="password"
            placeholder="••••••••"
            autocomplete="current-password"
            required>
        </div>
        <button class="btn-main" type="submit">Sign In</button>
      </form>

      <div class="divider">
        <div class="divider-line"></div>
        <span class="divider-text">or</span>
        <div class="divider-line"></div>
      </div>

      <a href="/auth/auth0" class="btn-auth0">
        <div class="auth0-mark"></div>
        Continue with Auth0
      </a>
    </div>

  </div>

</div>
</body>
</html>
