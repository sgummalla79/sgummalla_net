# ── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── CORS ─────────────────────────────────────────────────────────────────────
# URL of the Vue client app
CLIENT_URL=http://localhost:5173

# ── JWT ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=1h
JWT_COOKIE_NAME=vzen_token

# ── Auth0 ────────────────────────────────────────────────────────────────────
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_CALLBACK_URL=http://localhost:3000/api/auth0/callback

# ── SAML ─────────────────────────────────────────────────────────────────────
SAML_CALLBACK_URL=http://localhost:3000/api/saml/callback
SAML_ENTRY_POINT=
SAML_ISSUER=
SAML_CERT=

# ── OIDC ─────────────────────────────────────────────────────────────────────
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_CALLBACK_URL=http://localhost:3000/api/oidc/callback

# ── Credential Auth (temporary — replace with DB lookup in production) ────────
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me
