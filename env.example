# ─────────────────────────────────────────
# SAML IdP settings (this app IS the IdP)
# ─────────────────────────────────────────
# Entity ID that you register in Salesforce as the "Issuer"
SAML_ISSUER=http://localhost:3000/saml/metadata

# Salesforce Experience Cloud SSO settings
# ACS = Assertion Consumer Service URL (from Salesforce SSO config)
SALESFORCE_ACS_URL=https://your-org.my.salesforce.com/services/auth/saml/EC_SSO

# Salesforce Entity ID / Audience (from Salesforce SSO config)
SALESFORCE_ENTITY_ID=https://your-org.my.salesforce.com

# ─────────────────────────────────────────
# SAML attribute mapping
# These are the XML attribute names Salesforce expects
# ─────────────────────────────────────────
# NameID format to use
SAML_NAMEID_FORMAT=urn:oasis:names:tc:SAML:1.1:nameid-format:emailAddress
